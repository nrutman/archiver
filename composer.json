{
    "name": "nrutman/archiver",
    "description": "A Symfony and React app for creating temporary password-protected ZIP archives.",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.3",
        "ext-ctype": "*",
        "ext-fileinfo": "*",
        "ext-iconv": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-zip": "*",
        "pentatrion/vite-bundle": "^8.2",
        "symfony/asset": "7.4.*",
        "symfony/console": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/flex": "^2.10",
        "symfony/framework-bundle": "7.4.*",
        "symfony/runtime": "7.4.*",
        "symfony/twig-bundle": "7.4.*",
        "symfony/yaml": "7.4.*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95.2",
        "phpstan/phpstan": "^2.2.1",
        "phpstan/phpstan-symfony": "^2.0.18",
        "phpunit/phpunit": "^12.5.28",
        "symfony/browser-kit": "7.4.*",
        "symfony/css-selector": "7.4.*"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true,
        "platform": {
            "php": "8.3.31"
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "lint:container": "bin/console lint:container",
        "lint:twig": "bin/console lint:twig templates",
        "lint:yaml": "bin/console lint:yaml config",
        "lint": [
            "@lint:container",
            "@lint:twig",
            "@lint:yaml"
        ],
        "format": "php-cs-fixer fix --diff",
        "format:check": "php-cs-fixer fix --dry-run --diff",
        "analyse": "phpstan analyse --memory-limit=512M",
        "test": "php bin/phpunit",
        "check": [
            "composer validate --strict",
            "@lint",
            "@format:check",
            "@analyse",
            "@test"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*"
        }
    }
}
